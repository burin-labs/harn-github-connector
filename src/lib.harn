}

fn __actions_workflow_dispatch(args, cfg) {
  const workflow_id = args?.workflow_id ?? args?.workflow ?? args?.workflow_file
  if workflow_id == nil || trim(to_string(workflow_id)) == "" {
    return __err("schema_drift", "actions.workflow_dispatch requires workflow_id, workflow, or workflow_file")
  }
  const ref = args?.ref ?? args?.branch ?? "main"
  const body = {ref: ref, inputs: args?.inputs ?? {}, return_run_details: args?.return_run_details ?? true}
  return __github_json(
    "POST",
    __github_api_url(
      cfg.api_base_url,
      "/repos/" + args.owner + "/" + args.repo + "/actions/workflows/"
        + url_encode(to_string(workflow_id))
        + "/dispatches",
