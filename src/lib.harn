  const path = if workflow_id == nil || trim(to_string(workflow_id)) == "" {
    "/repos/" + args.owner + "/" + args.repo + "/actions/runs"
  } else {
    "/repos/" + args.owner + "/" + args.repo + "/actions/workflows/"
      + url_encode(to_string(workflow_id))
      + "/runs"
  }
  return __github_json(
