fn __issues_create_with_template(args, cfg) {
  const template = args?.template ?? {}
  const title_template = if type_of(template) == "dict" {
    template?.title ?? args?.title_template ?? args?.title ?? "Merge Captain follow-up"
  } else {
    args?.title_template ?? args?.title ?? "Merge Captain follow-up"
  }
  const body_template = if type_of(template) == "dict" {
    template?.body ?? args?.body_template ?? ""
  } else {
    to_string(template)
  }
  let body = {
    title: __render_template(title_template, args?.vars ?? {}),
    body: __render_template(body_template, args?.vars ?? {}),
  }
  const labels = args?.labels ?? if type_of(template) == "dict" {
    template?.labels
  } else {
    nil
  }
  if labels != nil {
    body["labels"] = labels
  }
  const assignees = args?.assignees ?? if type_of(template) == "dict" {
    template?.assignees
  } else {
    nil
  }
  if assignees != nil {
    body["assignees"] = assignees
  }
  const milestone = args?.milestone ?? if type_of(template) == "dict" {
    template?.milestone
  } else {
    nil
  }
  if milestone != nil {
    body["milestone"] = milestone
  }
  return __github_json(
    "POST",
    __github_api_url(cfg.api_base_url, "/repos/" + args.owner + "/" + args.repo + "/issues"),
    body,
    cfg,
  )
}

fn __pulls_list_with_checks(args, cfg) {
  const graph = __github_json(
    "POST",
    __github_api_url(cfg.api_base_url, "/graphql"),
    {
      query: __pulls_with_checks_query(),
      variables: {
        owner: args.owner,
        repo: args.repo,
        states: [uppercase(args?.state ?? "OPEN")],
        limit: min(max(to_int(args?.limit ?? 100) ?? 100, 1), 100),
        checkLimit: min(max(to_int(args?.check_limit ?? 50) ?? 50, 1), 100),
      },
    },
    cfg,
  )
  if is_err(graph) {
    return graph
  }
  const payload = graph
  if payload?.errors != nil && len(payload.errors) > 0 {
    return __err("graphql", "github GraphQL returned errors: " + json_stringify(payload.errors))
  }
  const nodes = payload?.data?.repository?.pullRequests?.nodes ?? []
  let pulls = []
  for node in nodes {
    pulls = pulls + [__normalize_graphql_pr(node)]
  }
  return pulls
}

fn __pulls_merge_safe(args, cfg) {
  const pull = __github_json(
    "GET",
    __github_api_url(
      cfg.api_base_url,
      "/repos/" + args.owner + "/" + args.repo + "/pulls/" + to_string(args.pull_number),
    ),
    nil,
    cfg,
  )
  if is_err(pull) {
    return pull
  }
  const base_branch = pull?.base?.ref ?? args?.base_branch
  const protection_result = __github_branch_protection_raw(
    {owner: to_string(args.owner), name: to_string(args.repo)},
    base_branch,
    cfg,
  )
  if is_err(protection_result) {
    return protection_result
  }
  const protection = unwrap(protection_result)
  const protected = protection != nil
  if protected && !(args?.admin_override ?? false) {
    return __err(
      "protected_branch_requires_admin_override",
      "base branch `" + to_string(base_branch)
        + "` is protected; pass admin_override to merge through it",
    )
  }
  const merged = __github_json(
    "PUT",
    __github_api_url(
      cfg.api_base_url,
      "/repos/" + args.owner + "/" + args.repo + "/pulls/" + to_string(args.pull_number) + "/merge",
    ),
    __merge_body(args, pull),
    cfg,
  )
  if is_err(merged) {
    return merged
  }
  let result = {
    pull_request: pull,
    protected: protected,
    branch_protection: protection,
    merge: __merge_annotation(merged, args),
  }
  if args?.delete_branch ?? false {
    const deleted = __delete_pull_head_branch(args, pull, cfg)
    if is_err(deleted) {
      return deleted
    }
    result["delete_branch"] = deleted
  }
  return result
}

fn __pulls_enable_auto_merge(args, cfg) {
  const pull = __github_json(
    "GET",
    __github_api_url(
      cfg.api_base_url,
      "/repos/" + args.owner + "/" + args.repo + "/pulls/" + to_string(args.pull_number),
    ),
    nil,
    cfg,
  )
  if is_err(pull) {
    return pull
  }
  if pull?.auto_merge != nil {
    return {
      repo: to_string(args.owner) + "/" + to_string(args.repo),
      pull_number: args.pull_number,
      state: "already_enabled",
      auto_merge: pull.auto_merge,
      pull_request: pull,
    }
  }
  const node_id = pull?.node_id
  if node_id == nil || trim(to_string(node_id)) == "" {
    return __err("schema_drift", "GitHub PR response did not include node_id for auto-merge")
  }
  const method = __graphql_merge_method(args?.method ?? args?.merge_method ?? "MERGE")
  if is_err(method) {
    return method
  }
  const graph = __github_json(
    "POST",
    __github_api_url(cfg.api_base_url, "/graphql"),
    {
      query: __enable_auto_merge_mutation(),
      variables: {
        pullRequestId: node_id,
        mergeMethod: unwrap(method),
        commitHeadline: args?.commit_headline ?? args?.commit_title,
        commitBody: args?.commit_body ?? args?.commit_message,
        expectedHeadOid: args?.expected_head_oid ?? args?.expectedHeadOid ?? pull?.head?.sha,
      },
    },
    cfg,
  )
  if is_err(graph) {
    return graph
  }
  if graph?.errors != nil && len(graph.errors) > 0 {
    return __err("graphql", "github GraphQL returned errors: " + json_stringify(graph.errors))
  }
  const enabled = graph?.data?.enablePullRequestAutoMerge ?? {}
  return {
    repo: to_string(args.owner) + "/" + to_string(args.repo),
    pull_number: args.pull_number,
    state: "enabled",
    requested_method: unwrap(method),
    pull_request: enabled?.pullRequest,
    actor: enabled?.actor,
    raw: enabled,
  }
}

fn __repos_get_text(args, cfg) {
  const content = __github_json(
    "GET",
    __github_api_url(
      cfg.api_base_url,
      "/repos/" + args.owner + "/" + args.repo + "/contents/"
        + __trim_leading_slash(args.path ?? "")
        + __ref_query(args),
    ),
    nil,
    cfg,
  )
  if is_err(content) {
    return content
  }
  if type_of(content) == "list" {
    return __err(
      "schema_drift",
      "repos.get_text requires a file path, but GitHub returned a directory listing",
    )
  }
  const encoding = lowercase(content?.encoding ?? "")
  if encoding != "base64" {
    return __err("invalid_response", "repos.get_text only supports base64-encoded GitHub file content")
  }
  const encoded = (content?.content ?? "").replace("\n", "")
  const decoded = try {
    base64_decode(encoded)
  }
  if is_err(decoded) {
    return __err("invalid_response", "repos.get_text could not decode base64 file content")
  }
  return {
    name: content?.name,
    path: content?.path,
    sha: content?.sha,
    size: content?.size,
    encoding: encoding,
    ref: args?.ref,
    text: unwrap(decoded),
    raw: if args?.include_raw ?? false {
      content
    } else {
      nil
    },
  }
}

fn __repos_get_latest_release(args, cfg) {
