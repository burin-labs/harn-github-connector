  GithubMergeQueueEntries,
  GithubMergeQueueEntry,
  GithubMergeQueueMembership,
  GithubMergeability,
  GithubPullRequestChecks,
  GithubPullRequestCommit,
  GithubPullRequestCommits,
  GithubPullRequestCreateReceipt,
  GithubPullRequestDetails,
