    "GET",
    BASE + "/repos/octo-org/octo-repo/commits/sha-2/check-runs",
    {
      status: 200,
      body: json_stringify(
        {
          check_runs: [
            {
              id: 90,
              name: "vendor-ci",
              status: "completed",
              conclusion: "failure",
              details_url: "https://example.com/builds/90",
            },
          ],
        },
      ),
      headers: {"x-ratelimit-remaining": "9"},
    },
  )
  const result = github_wait_for_pr_checks("octo-org", "octo-repo", "sha-2", auth() + {include_logs: true})
  assert_eq(result.state, "failing", "state=failing")
