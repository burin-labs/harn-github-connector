import {
  actions_workflow_dispatch,
  actions_workflow_run,
  actions_workflow_runs,
  api_call,
  call,
  github_latest_release,
  github_release_assets,
  pulls_enable_auto_merge,
  repos_get_latest_release,
  repos_get_text,
  repos_list_release_assets,
} from "../src/lib"

pipeline test_repo_automation_methods(task) {
  egress_policy({allow: ["github-api.test", "api.github.test"], default: "deny"})
  http_mock_clear()
  const base = "https://github-api.test"
  const token = "github-installation-token"
  const auth = {api_base_url: base, installation_token: token}
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/contents/.harn-version?ref=main",
    {
      status: 200,
      body: json_stringify(
        {
          name: ".harn-version",
          path: ".harn-version",
          sha: "file-sha",
          size: 7,
          encoding: "base64",
          content: base64_encode("v0.7.59\n"),
        },
      ),
      headers: {"x-ratelimit-remaining": "10"},
    },
  )
  const text = repos_get_text("octo-org", "octo-repo", ".harn-version", "main", auth)
  assert_eq(trim(text.text), "v0.7.59", "repos.get_text decodes base64 content")
  http_mock(
    "POST",
    base + "/repos/octo-org/octo-repo/actions/workflows/bump-harn.yml/dispatches",
    {
      status: 200,
      body: json_stringify(
        {
          workflow_run_id: 123,
          run_url: base + "/repos/octo-org/octo-repo/actions/runs/123",
          html_url: "https://github.com/octo-org/octo-repo/actions/runs/123",
        },
      ),
      headers: {"x-ratelimit-remaining": "9"},
    },
  )
  const dispatch = actions_workflow_dispatch(
    "octo-org",
    "octo-repo",
    "bump-harn.yml",
    "main",
    {version: "v0.7.59"},
    auth,
  )
  assert_eq(dispatch.workflow_run_id, 123, "workflow dispatch returns run id when GitHub provides it")
  http_mock(
    "GET",
    base
      + "/repos/octo-org/octo-repo/actions/workflows/bump-harn.yml/runs?event=workflow_dispatch&per_page=5",
    {
      status: 200,
      body: json_stringify(
        {
          total_count: 1,
          workflow_runs: [
            {
              id: 123,
              status: "completed",
              conclusion: "success",
              html_url: "https://github.com/octo-org/octo-repo/actions/runs/123",
            },
          ],
        },
      ),
      headers: {"x-ratelimit-remaining": "8"},
    },
  )
  const runs = actions_workflow_runs(
    "octo-org",
    "octo-repo",
    auth + {workflow_id: "bump-harn.yml", event: "workflow_dispatch", per_page: 5},
  )
  assert_eq(runs.workflow_runs[0].id, 123, "workflow runs list response")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/actions/runs/123",
    {
      status: 200,
      body: json_stringify({id: 123, status: "completed", conclusion: "success"}),
      headers: {"x-ratelimit-remaining": "7"},
    },
  )
  const run = actions_workflow_run("octo-org", "octo-repo", 123, auth)
  assert_eq(run.conclusion, "success", "workflow run get response")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/releases/latest",
    {
      status: 200,
      body: json_stringify(
        {
          id: 501,
          tag_name: "v0.8.4",
          name: "v0.8.4",
          draft: false,
          prerelease: false,
          html_url: "https://github.com/octo-org/octo-repo/releases/tag/v0.8.4",
          published_at: "2026-05-09T18:00:00Z",
          assets: [
            {id: 1, name: "harn-aarch64-apple-darwin.tar.gz"},
            {id: 2, name: "harn-x86_64-unknown-linux-gnu.tar.gz"},
          ],
        },
      ),
      headers: {"x-ratelimit-remaining": "7"},
    },
  )
  const raw_release = repos_get_latest_release("octo-org", "octo-repo", auth)
  assert_eq(raw_release.tag_name, "v0.8.4", "raw latest release tag")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/releases/latest",
    {
      status: 200,
      body: json_stringify(
        {
          id: 501,
          tag_name: "v0.8.4",
          assets: [
            {id: 1, name: "harn-aarch64-apple-darwin.tar.gz"},
            {id: 2, name: "harn-x86_64-unknown-linux-gnu.tar.gz"},
          ],
        },
      ),
      headers: {"x-ratelimit-remaining": "7"},
    },
  )
  const latest = github_latest_release("octo-org", "octo-repo", auth)
  assert_eq(latest.ok, true, "latest release envelope ok")
  assert_eq(latest.tag_name, "v0.8.4", "latest release envelope tag")
  assert_eq(
    latest.asset_names[1],
    "harn-x86_64-unknown-linux-gnu.tar.gz",
    "latest release asset names",
  )
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/releases/501/assets?per_page=2",
    {
      status: 200,
      body: json_stringify([{id: 1, name: "harn-aarch64-apple-darwin.tar.gz"}]),
      headers: {"x-ratelimit-remaining": "7"},
    },
  )
  const raw_assets = repos_list_release_assets("octo-org", "octo-repo", 501, auth + {per_page: 2})
  assert_eq(raw_assets[0].name, "harn-aarch64-apple-darwin.tar.gz", "raw release assets")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/releases/501/assets?per_page=2",
    {
      status: 200,
      body: json_stringify([{id: 2, name: "harn-x86_64-unknown-linux-gnu.tar.gz"}]),
      headers: {"x-ratelimit-remaining": "7"},
    },
  )
  const assets = github_release_assets("octo-org", "octo-repo", 501, auth + {per_page: 2})
  assert_eq(assets.ok, true, "release assets envelope ok")
  assert_eq(assets.asset_names[0], "harn-x86_64-unknown-linux-gnu.tar.gz", "release assets names")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/releases/latest",
    {status: 200, body: json_stringify({tag_name: "v0.8.4"}), headers: {"x-ratelimit-remaining": "7"}},
  )
  const raw = api_call("/repos/octo-org/octo-repo/releases/latest", "GET", nil, auth)
  assert_eq(raw.tag_name, "v0.8.4", "raw api_call works as compatibility escape hatch")
  http_mock(
    "GET",
    base + "/repos/octo-org/octo-repo/pulls/7",
    {
      status: 200,
      body: json_stringify(
        {
          number: 7,
          node_id: "PR_node_7",
          head: {sha: "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"},
          auto_merge: nil,
        },
      ),
      headers: {"x-ratelimit-remaining": "6"},
    },
  )
  http_mock(
    "POST",
    base + "/graphql",
    {
      status: 200,
      body: json_stringify(
        {
          data: {
            enablePullRequestAutoMerge: {
              actor: {login: "octocat"},
              pullRequest: {
                number: 7,
                url: "https://github.com/octo-org/octo-repo/pull/7",
                mergeStateStatus: "CLEAN",
                autoMergeRequest: {enabledAt: "2026-05-06T18:00:00Z", mergeMethod: "SQUASH"},
              },
            },
          },
        },
      ),
      headers: {"x-ratelimit-remaining": "5"},
    },
  )
  const auto_merge = pulls_enable_auto_merge("octo-org", "octo-repo", 7, auth + {method: "squash"})
  assert_eq(auto_merge.state, "enabled", "auto-merge enabled state")
  assert_eq(auto_merge.requested_method, "SQUASH", "auto-merge merge method normalized")
  const calls = http_mock_calls()
  const dispatch_body = json_parse(calls[1].body)
  const mutation_body = json_parse(calls[10].body)
  const mutation_vars = mutation_body.get("variables")
  assert_eq(dispatch_body.get("return_run_details"), true, "workflow dispatch asks for run details")
  assert_eq(mutation_vars.get("pullRequestId"), "PR_node_7", "auto-merge mutation uses PR node id")
  assert_eq(
    mutation_vars.get("expectedHeadOid"),
    "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
    "auto-merge mutation uses expected head oid",
  )
  assert(
    contains(mutation_body.get("query"), "enablePullRequestAutoMerge"),
    "auto-merge mutation name",
  )
  http_mock_clear()
}
